# Copy to .env and fill in real values
# NEVER commit .env — it's gitignored

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# Anthropic (for Claude-powered extraction scripts)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 (for direct S3 API access)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket

# Database backup (for backup-db-to-r2.sh)
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres
R2_BACKUP_BUCKET=finleg-backups
